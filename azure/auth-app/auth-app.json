{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.37.4.10188",
      "templateHash": "349564970680025313"
    }
  },
  "variables": {
    "displayName": "PortainerAuth",
    "app": "portainer-auth",
    "logoImage": ""
  },
  "imports": {
    "microsoftGraphV1": {
      "provider": "MicrosoftGraph",
      "version": "1.0.0"
    }
  },
  "resources": {
    "clientApp": {
      "import": "microsoftGraphV1",
      "type": "Microsoft.Graph/applications@v1.0",
      "properties": {
        "displayName": "[variables('displayName')]",
        "uniqueName": "[uniqueString(variables('app'))]",
        "logo": "[variables('logoImage')]",
        "web": {
          "redirectUris": [
            "https://portainer.newlandshc.xyz/"
          ]
        }
      }
    }
  },
  "outputs": {
    "appName": {
      "type": "string",
      "value": "[reference('clientApp').displayName]"
    },
    "logoUrl": {
      "type": "string",
      "value": "[if(equals(reference('clientApp').info.logoUrl, null()), 'Not yet set', reference('clientApp').info.logoUrl)]"
    }
  }
}